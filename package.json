{
	"name": "use-lanyard",
	"author": "Alistair Smith <hi@alistair.sh>",
	"version": "1.7.1",
	"type": "module",
	"description": "React hook for Lanyard for tracking your Discord presence.",
	"repository": "https://github.com/alii/use-lanyard",
	"main": "./dist/index.cjs",
	"types": "./dist/index.d.cts",
	"exports": {
		"./package.json": "./package.json",
		".": {
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"license": "MIT",
	"sideEffects": false,
	"files": [
		"./dist",
		"./README.md",
		"./LICENSE",
		"./package.json"
	],
	"engines": {
		"node": ">=18"
	},
	"scripts": {
		"build": "tsup",
		"release": "bun run build && bun publish",
		"example": "parcel ./example/index.html"
	},
	"keywords": [
		"discord",
		"presence",
		"react",
		"hook"
	],
	"dependencies": {
		"@prequist/lanyard": "^1.2.0"
	},
	"devDependencies": {
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"parcel": "^2.16.4",
		"process": "^0.11.10",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"tsup": "^8.5.1",
		"typescript": "^5.9.3"
	},
	"peerDependencies": {
		"react": "*",
		"react-dom": "*"
	},
	"trustedDependencies": [
		"@parcel/watcher",
		"@swc/core"
	]
}
